PORT=3000
APP_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="production"
QUEUE_DRIVER="bullmq"
APP_ENV="production"
REQUIRE_PRODUCTION_READY="true"
SESSION_TOKEN_TTL_HOURS="12"
TRIAL_TEST_HOURS="48"
MAX_UPLOAD_SIZE_MB="25"
DATA_DIR="./data"
UPLOAD_DIR="./data/uploads"
SQLITE_FILENAME="database.db"

# Comunicacao interna Node <-> WooAPI Core.
BRIDGE_URL="http://127.0.0.1:3001"
NODE_URL="http://localhost:3000"
BRIDGE_DB_PATH="./data/wooapi_bridge.db"
BRIDGE_TOKEN="troque-este-token-interno"
# Envio nativo de botoes/listas pelo WhatsApp Web e experimental e pode ser
# aceito pelo provider sem aparecer no telefone. Por padrao a API usa fallback
# textual confiavel; ative somente apos validar entrega real no seu numero.
EXPERIMENTAL_INTERACTIVE_MESSAGES="false"

# Segurança da API e assinatura dos webhooks.
JWT_SECRET="troque-este-segredo-jwt"
WEBHOOK_SECRET="troque-este-segredo-webhook"
WOOAPI_ADMIN_TOKEN="troque-este-admin-token"

# Supabase/PostgreSQL. OBRIGATÓRIO para produção. SQLite é apenas para dev local.
DB_TYPE="postgresql"
DATABASE_URL="postgresql://user:password@host:5432/wooapi?sslmode=require"

# Redis/BullMQ para filas WooAPI.
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_PASSWORD="troque-este-segredo-redis"
REDIS_URL="redis://:troque-este-segredo-redis@redis:6379"
REDIS_CONNECT_TIMEOUT_MS="10000"
DEFAULT_GLOBAL_RATE_LIMIT_PER_MINUTE="120"
DEFAULT_API_RATE_LIMIT_PER_MINUTE="60"
DEFAULT_ACCOUNT_RATE_LIMIT_PER_MINUTE="300"
DEFAULT_INSTANCE_RATE_LIMIT_PER_MINUTE="30"
DEFAULT_MESSAGE_RATE_LIMIT_PER_MINUTE="20"
DEFAULT_CRITICAL_RATE_LIMIT_PER_MINUTE="30"
TRAFFIC_GLOBAL_PER_MINUTE="600"
TRAFFIC_TENANT_PER_MINUTE="120"
TRAFFIC_INSTANCE_PER_MINUTE="20"
TRAFFIC_PHONE_PER_MINUTE="12"
TRAFFIC_NODE_PER_MINUTE="300"

# Workers
WEBHOOK_DELIVERY_TIMEOUT_MS="10000"
WEBHOOK_WORKER_CONCURRENCY="10"
MESSAGE_WORKER_CONCURRENCY="5"
MESSAGE_SEND_ATTEMPTS="5"
MESSAGE_SEND_BACKOFF_MS="15000"
TRAFFIC_WORKER_INLINE_DELAY_MAX_MS="8000"
MONITOR_INTERVAL_MS="60000"
MONITOR_OFFLINE_CRITICAL_MINUTES="5"
CORE_NODE_ID="core-node-local"
CORE_NODE_PROFILE="low-risk"
CORE_NODE_IP_POOL="local"
CORE_NODE_MAX_INSTANCES="150"
ORCHESTRATOR_INTERVAL_MS="30000"
CLEANUP_LOG_RETENTION_DAYS="30"

# Webhook padrao para novas instancias (opcional).
# Se definido, toda nova instancia ganha um webhook automaticamente com esta URL.
# Exemplo: DEFAULT_WEBHOOK_URL="https://meu-n8n.example.com/webhook/wooapi"
DEFAULT_WEBHOOK_URL=""

# SMTP para notificacoes de desconexao
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@wooapi.com.br"

# Instancia administradora para enviar notificacoes WhatsApp (opcional)
# Crie uma instância dedicada para suporte e coloque o ID e JID dela aqui
SUPPORT_INSTANCE_ID=""
SUPPORT_INSTANCE_JID=""

# Monitor worker - cooldown entre tentativas de reconexao automatica (ms)
MONITOR_RECONNECT_COOLDOWN_MS="300000"
QR_EXPIRES_MINUTES="10"
ORPHAN_SESSION_GRACE_MINUTES="30"

# Backups operacionais.
# Em PostgreSQL/Supabase, este backup cobre sessoes/midias locais; o dump do banco deve ser feito no provedor.
BACKUP_DIR="./data/backups"
ALLOW_RESTORE="false"

# Stripe para cobranca (OBRIGATORIO para producao)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
